{{#if success}}
  {{#if (eq success 'name')}}
  <div class="alert alert-success alert-dismissible">
    <button type="button" class="close" data-dismiss="alert">&times;</button>
    <i class="fa fa-check"></i> Display name updated successfully.
  </div>
  {{/if}}
  {{#if (eq success 'email')}}
  <div class="alert alert-success alert-dismissible">
    <button type="button" class="close" data-dismiss="alert">&times;</button>
    <i class="fa fa-check"></i> Email address updated successfully.
  </div>
  {{/if}}
  {{#if (eq success 'password')}}
  <div class="alert alert-success alert-dismissible">
    <button type="button" class="close" data-dismiss="alert">&times;</button>
    <i class="fa fa-check"></i> Password changed successfully.
  </div>
  {{/if}}
{{/if}}
{{#if error}}
<div class="alert alert-danger alert-dismissible">
  <button type="button" class="close" data-dismiss="alert">&times;</button>
  <i class="fa fa-exclamation-triangle"></i> {{error}}
</div>
{{/if}}

<div class="row">

  <!-- Left column: Profile + Email -->
  <div class="col-md-6">

    <!-- Change Name -->
    <div class="box box-primary">
      <div class="box-header with-border">
        <h3 class="box-title"><i class="fa fa-user"></i> Display Name</h3>
      </div>
      <div class="box-body">
        <form action="/settings/name" method="POST">
          <div class="form-group">
            <label>Full Name</label>
            <input type="text" name="full_name" class="form-control"
                   value="{{user.full_name}}" required maxlength="100">
          </div>
          <button type="submit" class="btn btn-primary btn-flat">
            <i class="fa fa-save"></i> Save Name
          </button>
        </form>
      </div>
    </div>

    <!-- Change Email -->
    <div class="box box-primary">
      <div class="box-header with-border">
        <h3 class="box-title"><i class="fa fa-envelope"></i> Email Address</h3>
      </div>
      <div class="box-body">
        <form action="/settings/email" method="POST">
          <div class="form-group">
            <label>Email</label>
            <input type="email" name="email" class="form-control"
                   value="{{user.email}}" required maxlength="120">
          </div>
          <button type="submit" class="btn btn-primary btn-flat">
            <i class="fa fa-save"></i> Save Email
          </button>
        </form>
      </div>
    </div>

  </div>

  <!-- Right column: Password + Appearance -->
  <div class="col-md-6">

    <!-- Change Password -->
    <div class="box box-warning">
      <div class="box-header with-border">
        <h3 class="box-title"><i class="fa fa-lock"></i> Change Password</h3>
      </div>
      <div class="box-body">
        <form action="/settings/password" method="POST">
          <div class="form-group">
            <label>Current Password</label>
            <input type="password" name="current_password" class="form-control"
                   placeholder="Enter your current password" required>
          </div>
          <div class="form-group">
            <label>New Password</label>
            <input type="password" name="new_password" class="form-control"
                   placeholder="At least 6 characters" required minlength="6">
          </div>
          <div class="form-group">
            <label>Confirm New Password</label>
            <input type="password" name="confirm_password" class="form-control"
                   placeholder="Repeat new password" required minlength="6">
          </div>
          <button type="submit" class="btn btn-warning btn-flat">
            <i class="fa fa-key"></i> Change Password
          </button>
        </form>
      </div>
    </div>

    <!-- Appearance -->
    <div class="box box-default">
      <div class="box-header with-border">
        <h3 class="box-title"><i class="fa fa-paint-brush"></i> Appearance</h3>
      </div>
      <div class="box-body">
        <div style="display:flex; align-items:center; justify-content:space-between; padding: 6px 0;">
          <div>
            <strong>Dark Mode</strong>
            <p class="text-muted" style="margin:2px 0 0;">Switch between light and dark theme.</p>
          </div>
          <label class="theme-switch" for="theme-toggle-checkbox" style="margin:0; cursor:pointer;">
            <input type="checkbox" id="theme-toggle-checkbox" />
            <div class="slider round"></div>
          </label>
        </div>
      </div>
    </div>

  </div>
</div>
