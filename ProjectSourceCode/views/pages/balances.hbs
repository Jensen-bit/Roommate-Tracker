<!-- Group Filter -->
<div class="row">
  <div class="col-xs-12">
    <div class="box box-info">
      <div class="box-header with-border">
        <h3 class="box-title"><i class="fa fa-users"></i> Filter by Group</h3>
      </div>
      <div class="box-body">
        <form action="/balances" method="GET" class="form-inline">
          <div class="form-group">
            <label class="control-label" style="margin-right:8px;">Group:</label>
            <select name="group" class="form-control">
              <option value="">All Roommates</option>
              {{#each groups}}
              <option value="{{group_id}}" {{#if (eq ../selectedGroupId group_id)}}selected{{/if}}>
                {{group_name}}
              </option>
              {{/each}}
            </select>
          </div>
          <button type="submit" class="btn btn-info btn-flat" style="margin-left:8px;">
            <i class="fa fa-filter"></i> Filter
          </button>
          {{#if selectedGroupId}}
          <a href="/balances" class="btn btn-default btn-flat" style="margin-left:8px;">
            <i class="fa fa-times"></i> Clear
          </a>
          {{/if}}
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Info Boxes -->
<div class="row">
  <div class="col-md-4 col-sm-6 col-xs-12">
    <div class="info-box bg-green">
      <span class="info-box-icon"><i class="fa fa-arrow-down"></i></span>
      <div class="info-box-content">
        <span class="info-box-text">Total Owed to You</span>
        <span class="info-box-number" id="total-owed-to-you">—</span>
      </div>
    </div>
  </div>
  <div class="col-md-4 col-sm-6 col-xs-12">
    <div class="info-box bg-red">
      <span class="info-box-icon"><i class="fa fa-arrow-up"></i></span>
      <div class="info-box-content">
        <span class="info-box-text">Total You Owe</span>
        <span class="info-box-number" id="total-you-owe">—</span>
      </div>
    </div>
  </div>
  <div class="col-md-4 col-sm-6 col-xs-12">
    <div class="info-box bg-aqua">
      <span class="info-box-icon"><i class="fa fa-users"></i></span>
      <div class="info-box-content">
        <span class="info-box-text">{{#if selectedGroup}}{{selectedGroup.group_name}}{{else}}All Roommates{{/if}}</span>
        <span class="info-box-number">{{balances.length}}</span>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <!-- Roommate Balances -->
  <div class="col-md-5">
    <div class="box box-primary">
      <div class="box-header with-border">
        <h3 class="box-title">
          <i class="fa fa-balance-scale"></i>
          {{#if selectedGroup}}{{selectedGroup.group_name}} Balances{{else}}Roommate Balances{{/if}}
        </h3>
      </div>
      <div class="box-body">
        {{#if balances.length}}
        <ul class="list-group">
          {{#each balances}}
          <li class="list-group-item">
            <span class="{{color_class}}">
              {{#if is_zero}}
                <i class="fa fa-check text-muted"></i>
                <span class="text-muted">{{display_text}}</span>
              {{else}}
                <strong>{{display_text}}</strong>
              {{/if}}
            </span>
          </li>
          {{/each}}
        </ul>
        {{else}}
        <p class="text-muted text-center" style="padding:20px;">
          <i class="fa fa-check-circle fa-3x"></i><br>All settled up!
        </p>
        {{/if}}
      </div>
    </div>
  </div>

  <!-- Outstanding Shares -->
  <div class="col-md-7">
    <div class="box box-warning">
      <div class="box-header with-border">
        <h3 class="box-title"><i class="fa fa-clock-o"></i> Outstanding Shares</h3>
      </div>
      <div class="box-body no-padding">
        {{#if unpaidShares.length}}
        <table class="table table-hover table-condensed">
          <thead>
            <tr>
              <th>Description</th>
              <th>Who Owes</th>
              <th>Amount</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            {{#each unpaidShares}}
            <tr>
              <td>{{description}}</td>
              <td>{{owes_user}}</td>
              <td><span class="label label-danger">${{amount_owed}}</span></td>
              <td>
                <form action="/mark-paid/{{participant_id}}" method="POST" style="display:inline;">
                  <button type="submit" class="btn btn-xs btn-success btn-flat">
                    <i class="fa fa-check"></i> Mark Paid
                  </button>
                </form>
              </td>
            </tr>
            {{/each}}
          </tbody>
        </table>
        {{else}}
        <p class="text-muted text-center" style="padding:20px;">
          <i class="fa fa-check-circle fa-3x"></i><br>No outstanding shares.
        </p>
        {{/if}}
      </div>
    </div>
  </div>
</div>

<script>
  var balanceData = [{{#each balances}}{ net: {{net_balance}} }{{#unless @last}},{{/unless}}{{/each}}];
  var owedToMe = 0, iOwe = 0;
  balanceData.forEach(function(b) {
    if (b.net > 0) owedToMe += b.net;
    else if (b.net < 0) iOwe += Math.abs(b.net);
  });
  document.getElementById('total-owed-to-you').textContent = '$' + owedToMe.toFixed(2);
  document.getElementById('total-you-owe').textContent = '$' + iOwe.toFixed(2);
</script>
