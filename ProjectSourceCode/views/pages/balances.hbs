<div class="container mt-4">
  <h2 class="mb-4">Current Balances With Roommates</h2>

  {{#if balances.length}}
    <div class="row">
      {{#each balances}}
        <div class="col-md-6 col-lg-4 mb-3">
          <div class="card shadow-sm">
            <div class="card-body">
              <h5 class="card-title">{{this.roommate_name}}</h5>

              {{#if this.is_zero}}
                <p class="card-text text-secondary fw-bold mb-0">
                  $0.00 — Settled up
                </p>
              {{else}}
                <p class="card-text fw-bold mb-0 {{this.color_class}}">
                  {{this.display_text}}
                </p>
              {{/if}}
            </div>
          </div>
        </div>
      {{/each}}
    </div>
  {{else}}
    <p>No roommate balances found yet.</p>
  {{/if}}

  <hr class="my-4">

  <h3 class="mb-3">Unpaid Expense Shares</h3>

  {{#if unpaidShares.length}}
    <div class="row">
      {{#each unpaidShares}}
        <div class="col-md-6 col-lg-4 mb-3">
          <div class="card border-warning shadow-sm">
            <div class="card-body">
              <h5 class="card-title">{{this.description}}</h5>
              <p class="card-text mb-2">
                {{this.owes_user}} owes ${{this.amount_owed}}
              </p>

              <form action="/mark-paid/{{this.participant_id}}" method="POST">
                <button type="submit" class="btn btn-success btn-sm">
                  Mark as Paid
                </button>
              </form>
            </div>
          </div>
        </div>
      {{/each}}
    </div>
  {{else}}
    <p>There are no unpaid expense shares.</p>
  {{/if}}
</div>