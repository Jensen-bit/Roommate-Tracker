<div class="row">
  <div class="col-xs-12">
    <div class="box box-info">
      <div class="box-header with-border">
        <h3 class="box-title"><i class="fa fa-filter"></i> Filter by Roommate</h3>
      </div>
      <div class="box-body">
        <form action="/payment-history" method="GET" class="form-inline">
          <div class="form-group">
            <label class="control-label" style="margin-right:8px;">Roommate:</label>
            <select name="roommate" class="form-control">
              <option value="">All Roommates</option>
              {{#each roommates}}
              <option value="{{user_id}}" {{#if (eq ../selectedRoommate user_id)}}selected{{/if}}>
                {{full_name}}
              </option>
              {{/each}}
            </select>
          </div>
          <button type="submit" class="btn btn-info btn-flat" style="margin-left:8px;">
            <i class="fa fa-search"></i> Filter
          </button>
          {{#if selectedRoommate}}
          <a href="/payment-history" class="btn btn-default btn-flat" style="margin-left:8px;">
            <i class="fa fa-times"></i> Clear
          </a>
          {{/if}}
        </form>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-xs-12">
    <div class="box box-success">
      <div class="box-header with-border">
        <h3 class="box-title"><i class="fa fa-history"></i> Payment Records</h3>
        <div class="box-tools pull-right">
          <span class="badge bg-green">{{history.length}} records</span>
        </div>
      </div>
      <div class="box-body no-padding">
        {{#if history.length}}
        <table class="table table-striped table-hover">
          <thead>
            <tr>
              <th>#</th>
              <th>Description</th>
              <th>Paid By</th>
              <th>Roommate</th>
              <th>Amount</th>
              <th>Expense Date</th>
              <th>Paid On</th>
              <th>Details</th>
            </tr>
          </thead>
          <tbody>
            {{#each history}}
            <tr>
              <td>{{@index}}</td>
              <td>{{description}}</td>
              <td><span class="label label-primary">{{paid_by_name}}</span></td>
              <td>{{roommate_name}}</td>
              <td><strong>${{amount_owed}}</strong></td>
              <td><small class="text-muted">{{created_at}}</small></td>
              <td><small class="text-muted">{{paid_at}}</small></td>
              <td>
                <a href="/payment-history/{{participant_id}}" class="btn btn-xs btn-default btn-flat">
                  <i class="fa fa-eye"></i> View
                </a>
              </td>
            </tr>
            {{/each}}
          </tbody>
        </table>
        {{else}}
        <div class="text-center" style="padding:40px;">
          <i class="fa fa-inbox fa-4x text-muted"></i>
          <p class="text-muted" style="margin-top:10px;">No payment history found.</p>
        </div>
        {{/if}}
      </div>
    </div>
  </div>
</div>
